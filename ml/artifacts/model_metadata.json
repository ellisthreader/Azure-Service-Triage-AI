{
  "model_name": "service-priority-ai-baseline",
  "model_version": "0.1.0",
  "model_type": "scikit-learn LogisticRegression pipeline",
  "features": [
    "service_type",
    "service_subtype",
    "district",
    "month",
    "source_system",
    "sla_hours",
    "out_of_hours",
    "accessibility_need",
    "duplicate_signal",
    "days_open",
    "previous_contacts",
    "vulnerability_flag",
    "deprivation_band",
    "channel",
    "urgency_text"
  ],
  "target": "priority",
  "classes": [
    "high",
    "low",
    "medium"
  ],
  "training_rows": 20000,
  "validation_rows": 5000,
  "intended_use": "Advisory prioritisation for fictional service requests with human review.",
  "not_for": "Automated denial, eligibility decisions, or live services without governance approval."
}